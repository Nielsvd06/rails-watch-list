<div class="banner" style="background-image: linear-gradient(rgba(0,0,0,0.4),rgba(0,0,0,0.4)), url('https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?ixlib=rb-1.2.1&auto=format&fit=crop&w=1350&q=80');">
  <div class="container">
    <h1><%= @list.name %></h1>
    <span class="badge bg-primary"><%= @list.movies.count %> movies</span>
  </div>
</div>

<div class="container my-5">
  <div class="movie-grid">
    <% @list.bookmarks.each do |bookmark| %>
      <div class="movie-card">
        <img src="<%= bookmark.movie.poster_url %>" alt="<%= bookmark.movie.title %>" class="movie-card-img">
        <div class="movie-card-content">
          <div class="d-flex justify-content-between align-items-center mb-2">
            <h3><%= bookmark.movie.title %></h3>
            <span class="text-muted"><%= bookmark.movie.rating %> <i class="fas fa-star text-warning"></i></span>
          </div>
          <p class="overview"><%= bookmark.movie.overview %></p>

          <div class="movie-card-footer">
            <small><i class="fas fa-quote-left me-2"></i><%= bookmark.comment %></small>
            <%= link_to bookmark_path(bookmark), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "text-danger" do %>
              <i class="fas fa-trash"></i>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="mt-5">
    <%= link_to "Add a movie", new_list_bookmark_path(@list), class: "btn btn-success" %>
    <%= link_to "Back to lists", lists_path, class: "btn btn-light ms-2" %>
  </div>
</div>
